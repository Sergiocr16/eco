{
  "name": "@eco/backend",
  "version": "0.1.0",
  "description": "Backend de Eco: envuelve Claude Agent SDK y expone WebSocket",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx/esm src/index.ts",
    "start:dist": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:security": "node tests/security.mjs",
    "test:client": "node tests/client.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@node-rs/argon2": "^2.0.2",
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
