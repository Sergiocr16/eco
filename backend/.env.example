# Workspaces que Eco puede tocar (coma-separados). Acepta uno o varios.
ECO_WORKSPACES=/Users/sergio/projects/aditum-jh,/Users/sergio/Documents

# Bind interface — 127.0.0.1 only (NUNCA 0.0.0.0)
ECO_HOST=127.0.0.1
ECO_PORT=7000

# Orígenes permitidos para WebSocket (Tauri webview + Vite dev).
ECO_ALLOWED_ORIGINS=tauri://localhost,http://localhost:5173,http://127.0.0.1:5173

# Modelo de Claude
ECO_MODEL=claude-sonnet-4-5-20250929

# Path al binario claude (autodetecta si no se especifica)
# CLAUDE_CLI_PATH=/Users/sergio/.local/bin/claude

# API key — OPCIONAL. Si el CLI ya está autenticado con `claude login` no hace falta.
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Rate limit por conexión (prompts por minuto)
ECO_RATE_LIMIT=10
