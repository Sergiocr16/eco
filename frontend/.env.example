# Token de autenticación contra el backend local (~/.eco/token).
# En dev web: copialo del archivo. En Electron: lo inyecta el preload.
VITE_ECO_TOKEN=

# URL del backend local (vacío en dev web para usar el proxy de Vite).
VITE_ECO_BACKEND=

# --- Firebase (multi-tenant: Auth + Firestore como fuente de verdad) ---
# Esta config web es PÚBLICA (no es secreta): la seguridad real son las
# Security Rules en firestore.rules. Copiá los valores de la consola de
# Firebase → Project settings → tu web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
