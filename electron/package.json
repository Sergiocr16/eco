{
  "name": "eco-desktop",
  "productName": "Eco",
  "version": "1.0.0",
  "description": "Eco — asistente local para macOS/Windows/Linux",
  "main": "main.cjs",
  "private": true,
  "author": {
    "name": "Sergio Castro",
    "email": "partners@aditumcr.com"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --config electron-builder.config.cjs",
    "build:mac": "electron-builder --config electron-builder.config.cjs --mac dmg",
    "build:mac-dir": "electron-builder --config electron-builder.config.cjs --mac dir",
    "build:win": "electron-builder --config electron-builder.config.cjs --win nsis",
    "build:win-dir": "electron-builder --config electron-builder.config.cjs --win dir",
    "build:linux": "electron-builder --config electron-builder.config.cjs --linux AppImage"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  }
}
