{
  "name": "eco-desktop",
  "productName": "Eco",
  "version": "0.1.0",
  "description": "Eco — asistente local para macOS/Windows/Linux",
  "main": "main.cjs",
  "private": true,
  "author": {
    "name": "Sergio Castro",
    "email": "partners@aditumcr.com"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aditum.eco",
    "productName": "Eco",
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "asarUnpack": [
      "**/node-pty/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "../release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/*.{md,markdown,ts,map}",
          "!**/test/**",
          "!**/tests/**",
          "!**/example/**",
          "!**/examples/**",
          "!**/.bin/**"
        ]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "build/bin",
        "to": "bin",
        "filter": ["eco-stt"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Eco usa el micrófono para tus comandos de voz (transcripción local con el motor de Apple en el dispositivo).",
        "NSSpeechRecognitionUsageDescription": "Eco transcribe tus comandos de voz usando el reconocimiento on-device de Apple — el audio no sale de tu Mac."
      }
    },
    "dmg": {
      "title": "Eco ${version}",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.png"
    }
  }
}
