{
  "name": "eco-desktop",
  "productName": "Eco",
  "version": "1.0.0",
  "description": "Eco — asistente local para macOS/Windows/Linux",
  "main": "main.cjs",
  "private": true,
  "author": {
    "name": "Sergio Castro",
    "email": "partners@aditumcr.com"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac dmg",
    "build:mac-dir": "electron-builder --mac dir",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aditum.eco",
    "productName": "Eco",
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "asarUnpack": [
      "**/node-pty/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "../release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/*.{md,markdown,ts,map,d.ts.map}",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/example/**",
          "!**/examples/**",
          "!**/docs/**",
          "!**/.bin/**",
          "!**/*.tsbuildinfo",
          "!**/LICENSE*",
          "!**/CHANGELOG*",
          "!**/AUTHORS*",
          "!**/CONTRIBUTING*",
          "!**/HISTORY*",
          "!**/.github/**",
          "!**/.vscode/**",
          "!**/@anthropic-ai/claude-agent-sdk/vendor/ripgrep/arm64-linux/**",
          "!**/@anthropic-ai/claude-agent-sdk/vendor/ripgrep/x64-darwin/**",
          "!**/@anthropic-ai/claude-agent-sdk/vendor/ripgrep/x64-linux/**",
          "!**/@anthropic-ai/claude-agent-sdk/vendor/ripgrep/x64-win32/**",
          "!**/node-pty/prebuilds/darwin-x64/**",
          "!**/node-pty/prebuilds/win32-arm64/**",
          "!**/node-pty/prebuilds/win32-x64/**",
          "!**/node-pty/deps/winpty/**",
          "!**/node-pty/build/**",
          "!**/node-pty/src/**",
          "!**/node-pty/scripts/**",
          "!**/node-pty/tools/**",
          "!**/bip39/src/wordlists/chinese_simplified.json",
          "!**/bip39/src/wordlists/chinese_traditional.json",
          "!**/bip39/src/wordlists/czech.json",
          "!**/bip39/src/wordlists/french.json",
          "!**/bip39/src/wordlists/italian.json",
          "!**/bip39/src/wordlists/japanese.json",
          "!**/bip39/src/wordlists/korean.json",
          "!**/bip39/src/wordlists/portuguese.json",
          "!**/bip39/src/wordlists/spanish.json",
          "!**/typescript/**",
          "!**/esbuild/**",
          "!**/tsx/**",
          "!**/@types/**"
        ]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "build/bin",
        "to": "bin",
        "filter": ["eco-stt"]
      },
      {
        "from": "../mcp-server/dist",
        "to": "mcp-server/dist"
      },
      {
        "from": "../mcp-server/node_modules",
        "to": "mcp-server/node_modules",
        "filter": [
          "**/*",
          "!**/*.{md,markdown,ts,map,d.ts.map}",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/example/**",
          "!**/examples/**",
          "!**/docs/**",
          "!**/.bin/**",
          "!**/*.tsbuildinfo",
          "!**/LICENSE*",
          "!**/CHANGELOG*",
          "!**/.github/**",
          "!**/.vscode/**"
        ]
      },
      {
        "from": "../mcp-server/package.json",
        "to": "mcp-server/package.json"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Eco usa el micrófono para dictar a la terminal (transcripción local con el motor de Apple en el dispositivo).",
        "NSSpeechRecognitionUsageDescription": "Eco transcribe tu dictado a la terminal usando el reconocimiento on-device de Apple — el audio no sale de tu Mac."
      },
      "electronLanguages": [
        "en",
        "es"
      ]
    },
    "dmg": {
      "title": "Eco ${version}",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
